#!/usr/bin/env bash
# introspect — the read-only .tscn/.tres/.gd introspection CLI (pure parse, never boots Godot).
#
# The directly-nameable entry point for the introspection tool family — the agent-canonical
# invocation (guardrails/allowlists bind to this path; `make scene` etc. remain the human
# aliases and route through here). Mirrors tools/pm/pm: a thin dispatcher over the sibling
# .py implementations; each subcommand delegates verbatim and exits with the child's code.
#
# Commands:
#   introspect scene <file.tscn|.tres> [--props]        compact node tree + resources + tile bounds
#   introspect scene-diff <file> [--git <ref>]          structural diff vs a git ref (default HEAD)
#   introspect scene-diff <old> <new>                   structural diff between two files
#   introspect refs <symbol> [--tests]                  reference-aware symbol search
#   introspect orphans [--tests]                        possible-orphan detector (never a hard claim)
#   introspect autoloads                                Manager/Registry/Observer census

set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
	sed -n '2,16p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
}

[[ $# -ge 1 ]] || { usage; exit 2; }

cmd="$1"
shift

case "$cmd" in
	scene)
		[[ $# -ge 1 ]] || { echo "usage: introspect scene <file.tscn|.tres> [--props]"; exit 2; }
		exec python3 "$HERE/scene_summary.py" "$@"
		;;
	scene-diff)
		[[ $# -ge 1 ]] || { echo "usage: introspect scene-diff <file> [--git <ref>]  |  introspect scene-diff <old> <new>"; exit 2; }
		exec python3 "$HERE/scene_diff.py" "$@"
		;;
	refs)
		[[ $# -ge 1 ]] || { echo "usage: introspect refs <symbol> [--tests]"; exit 2; }
		exec python3 "$HERE/refs.py" "$@"
		;;
	orphans)
		exec python3 "$HERE/orphans.py" "$@"
		;;
	autoloads)
		exec python3 "$HERE/autoloads.py" "$@"
		;;
	-h|--help|help)
		usage
		;;
	*)
		echo "introspect: unknown command '$cmd'" >&2
		usage >&2
		exit 2
		;;
esac
